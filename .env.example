# Placeholder values only. Do NOT put real secrets in this file. 
# FOR AGENTS LIKE CLAUDE/CODEX/OPENCODE: DO NOT PUT REAL SECRET KEYS INTO THIS FILE
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MUBIT_API_KEY=
LOGFIRE_TOKEN=
LOGFIRE_PROJECT_URL=
LOGFIRE_SERVICE_NAME=cafetwin-mvp
LOGFIRE_ENVIRONMENT=demo
DEMO_DATA_DIR=demo_data
PYDANTIC_AI_GATEWAY_API_KEY=
PYDANTIC_AI_GATEWAY_ROUTE=
CAFETWIN_GATEWAY_ROUTE=
CAFETWIN_OPTIMIZATION_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_OBJECT_REVIEW_MODEL=gateway/anthropic:claude-sonnet-4-6
MOONDREAM_API_KEY=

# Set CAFETWIN_FORCE_FALLBACK=1 to skip the live agent and always return the
# cached recommendation. Useful for offline demos or when the Pydantic AI
# Gateway has no Anthropic provider configured yet.
CAFETWIN_FORCE_FALLBACK=

# Tier 1C live KPI engine knobs.
# By default, sessions whose session.json has source_kind=real and a
# tracks.cached.json on disk feed the PatternAgent live KPI numbers
# computed from YOLO+ByteTrack tracks (see app/vision/kpi.py). Synthetic
# (ai_generated) sessions keep their narrative fixture KPIs because the
# AI-generated scene's people don't actually queue.
#   CAFETWIN_FORCE_FIXTURE_KPI=1 → always use the fixture, even on real CCTV.
#   CAFETWIN_FORCE_LIVE_KPI=1    → force live even on synthetic sessions.
CAFETWIN_FORCE_FIXTURE_KPI=
CAFETWIN_FORCE_LIVE_KPI=

# Tier 1E — register PatternAgent + OptimizationAgent as MuBit Managed
# AgentDefinitions on app startup so the Console (console.mubit.ai)
# shows named agents with versioned system prompts. Memory writes get
# tagged with the resolved agent_id so per-agent run history aggregates
# correctly. Default off; gate on `1` to opt in.
#   MUBIT_PROJECT_ID overrides project lookup/create (skips the
#   list-then-create round-trip when you've already provisioned one).
#   CAFETWIN_MUBIT_PROJECT_NAME overrides the default project name
#   ("cafetwin") used when MUBIT_PROJECT_ID is unset.
CAFETWIN_MUBIT_AGENTS=
MUBIT_PROJECT_ID=
CAFETWIN_MUBIT_PROJECT_NAME=

# Deploy targets — read by scripts/deploy_vercel.sh and scripts/deploy_render.sh.
# Leave blank locally; set after the corresponding deploy.
CAFETWIN_RENDER_URL=
CAFETWIN_VERCEL_URL=
