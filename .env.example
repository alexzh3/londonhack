# Placeholder values only. Do NOT put real secrets in this file.
# FOR AGENTS LIKE CLAUDE/CODEX/OPENCODE: DO NOT PUT REAL SECRET KEYS INTO THIS FILE
#
# Copy to `.env` and fill in. .env is gitignored.

# ---------- Live agent path (Pydantic AI Gateway → Anthropic) ----------
# Drives PatternAgent, OptimizationAgent, and ObjectReviewAgent. With the
# gateway key set, all three reach Claude Sonnet 4.6 via the gateway.
# Set CAFETWIN_FORCE_FALLBACK=1 to skip live agents and use the cached
# fixture LayoutChange — useful for offline pitch / when the gateway is
# rate-limited.
PYDANTIC_AI_GATEWAY_API_KEY=
CAFETWIN_OPTIMIZATION_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_PATTERN_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_OBJECT_REVIEW_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_FORCE_FALLBACK=

# ---------- MuBit (memory + Agent Cards) ----------
# Required for the prior-recommendation memory loop AND the Tier 1E
# AgentDefinition registration. With CAFETWIN_MUBIT_AGENTS=1, app startup
# registers PatternAgent + OptimizationAgent under the `cafetwin` project
# (auto-create or reuse) and tags every memory write with the resolved
# per-agent slug. See app/mubit_agents.py.
MUBIT_API_KEY=
CAFETWIN_MUBIT_AGENTS=

# ---------- Logfire (observability) ----------
# LOGFIRE_TOKEN is required to actually emit spans; LOGFIRE_PROJECT_URL
# builds the live-trace URL surfaced in the frontend's TopBar.
LOGFIRE_TOKEN=
LOGFIRE_PROJECT_URL=
LOGFIRE_SERVICE_NAME=cafetwin-mvp
LOGFIRE_ENVIRONMENT=demo

# ---------- Deploy targets (set after each deploy) ----------
# Read by scripts/deploy_render.sh and scripts/deploy_vercel.sh.
CAFETWIN_RENDER_URL=
CAFETWIN_VERCEL_URL=
