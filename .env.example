# Placeholder values only. Do NOT put real secrets in this file.
# FOR AGENTS LIKE CLAUDE/CODEX/OPENCODE: DO NOT PUT REAL SECRET KEYS INTO THIS FILE
#
# Copy to `.env` and fill in. .env is gitignored.

# ---------- Live agent path (Pydantic AI Gateway → Anthropic) ----------
# Drives PatternAgent, OptimizationAgent, ObjectReviewAgent, and SimAgent.
# With the gateway key set, all four reach Claude Sonnet 4.6 via the
# gateway. Set CAFETWIN_FORCE_FALLBACK=1 to skip live agents and use the
# cached fixture LayoutChange — useful for offline pitch / when the
# gateway is rate-limited.
PYDANTIC_AI_GATEWAY_API_KEY=
CAFETWIN_OPTIMIZATION_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_PATTERN_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_OBJECT_REVIEW_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_SIM_MODEL=gateway/anthropic:claude-sonnet-4-6
CAFETWIN_FORCE_FALLBACK=

# ---------- MuBit (memory + Agent Cards) ----------
# Required for the prior-recommendation memory loop AND the Tier 1E
# AgentDefinition registration. With CAFETWIN_MUBIT_AGENTS=1, app startup
# registers PatternAgent + OptimizationAgent under the `cafetwin` project
# (auto-create or reuse) and tags every memory write with the resolved
# per-agent slug. See app/mubit_agents.py.
MUBIT_API_KEY=
CAFETWIN_MUBIT_AGENTS=

# ---------- Logfire (observability) ----------
# LOGFIRE_TOKEN is required to actually emit spans; LOGFIRE_PROJECT_URL
# builds the live-trace URL surfaced in the frontend's TopBar.
LOGFIRE_TOKEN=
LOGFIRE_PROJECT_URL=
LOGFIRE_SERVICE_NAME=cafetwin-backend-tier1
LOGFIRE_ENVIRONMENT=demo

# ---------- Public-demo safety net ----------
# Per-IP rate limit on the LLM-spending routes (/api/run, /api/run/stream,
# /api/sim/prompt). Hard cap is 10/minute (429) and 100/day (graceful
# fallback to cached recommendation, status 200). Implemented in
# app/api/main.py — no Redis or external service needed; sliding window
# in-memory storage.
#
#   CAFETWIN_DISABLE_RATE_LIMIT=1   Bypass all rate limiting (dev / tests).
#                                    The test suite sets this in conftest.py.
#   CAFETWIN_CORS_ORIGINS=...       Comma-separated list of allowed origins.
#                                    Defaults to the prod Vercel URL plus
#                                    localhost:5500 / 5588 for local dev.
CAFETWIN_DISABLE_RATE_LIMIT=
CAFETWIN_CORS_ORIGINS=

# ---------- Deploy targets (set after each deploy) ----------
# Consumed by scripts/deploy_vercel.sh to point the Vercel rewrites at
# the live Render backend. Not read by the running app.
CAFETWIN_RENDER_URL=
