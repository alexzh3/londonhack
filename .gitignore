# Local secrets and environment files
.env
.env.*
!.env.example
!.env.sample

# Common secret material
*.pem
*.key
*.p12
*.pfx
secrets/

# Python / uv local artifacts
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Runtime demo output (memory writes accumulate here at demo time)
demo_data/mubit_fallback.jsonl

# Downloaded model weights for local/offline vision scripts
models/
*.pt

# Generated visual artifacts and screenshots
images/

# Vision pipeline overlay videos (pitch artifacts; multi-MB; not runtime data).
# Source CCTV under cafe_videos/ stays tracked. The H.264 web-safe transcode
# (annotated_before.web.mp4) is regenerated via scripts/transcode_annotated_for_web.sh.
**/annotated_before.mp4
**/annotated_before.web.mp4
**/object_detections.annotated.jpg
**/object_detections.moondream.jpg
**/object_detections.moondream.local.cached.json
**/object_detections.moondream.05b_mf*.cached.json
**/object_detections.moondream.05b_mf*.jpg
**/moondream_local_benchmark.json
**/moondream_05b_mf*_benchmark.json
**/object_detector_benchmark/

# Playwright MCP local screenshots from manual verification runs.
tier_1*.png

# Playwright MCP session artifacts (snapshots, console logs, network logs)
.playwright-mcp/

# Per-agent local config / scratch dirs
.codex
.agents/
.claude/
.factory/
.devin/

# Locally installed skills (the actual skill content lives in agent-private
# dirs like .agents/skills/, ~/.codex/skills/, etc.) — these symlinks and the
# lock file are local-only state.
skills/
skills-lock.json

# Deploy artifacts (generated per environment, never committed)
frontend/vercel.json
frontend/.vercel/
.vercel/

# Node / JS (defensive — no JS build today, but agents and tooling sometimes drop these)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Logs
*.log
logs/

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
